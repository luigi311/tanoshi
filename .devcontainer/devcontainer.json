// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"image": "ghcr.io/luigi311/tanoshi-builder:sha-6e8cc9c",

	// Features to add to the dev container. More info: https://containers.dev/features.
	//"features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"vadimcn.vscode-lldb",
				"ms-azuretools.vscode-docker",
				"tamasfe.even-better-toml",
				"fill-labs.dependi",
				"esbenp.prettier-vscode",
				"github.vscode-github-actions",
				"rust-lang.rust-analyzer",
			]
		}
	},

	// Run as the existing 'ubuntu' user, with UID/GID mapped to match the host
	// so files created in the container have correct host permissions.
	// Skips remapping for root-owned workspaces and for UIDs/GIDs already
	// taken in the container, so container creation never fails on the remap.
	"onCreateCommand": "HOST_UID=$(stat -c '%u' /workspaces/${localWorkspaceFolderBasename}); HOST_GID=$(stat -c '%g' /workspaces/${localWorkspaceFolderBasename}); if [ \"$HOST_UID\" = \"0\" ]; then echo 'workspace owned by root; skipping UID/GID remap'; exit 0; fi; if [ \"$(id -g ubuntu)\" != \"$HOST_GID\" ]; then if getent group \"$HOST_GID\" >/dev/null; then echo \"GID $HOST_GID already in use; skipping groupmod\"; else groupmod --gid \"$HOST_GID\" ubuntu; fi; fi; if [ \"$(id -u ubuntu)\" != \"$HOST_UID\" ]; then if getent passwd \"$HOST_UID\" >/dev/null; then echo \"UID $HOST_UID already in use; skipping usermod\"; else usermod --uid \"$HOST_UID\" ubuntu; fi; fi; chown -R \"$(id -u ubuntu):$(id -g ubuntu)\" /home/ubuntu",
	"remoteUser": "ubuntu"
}
